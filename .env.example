# DentaScale environment variables
# Copy this file to ".env.local" and fill in your real values.
# All vars are NEXT_PUBLIC_* because they run in the browser.

# --- Lead form delivery -----------------------------------------------------
# Web3Forms access key. Get a free key (no account needed) at:
# https://web3forms.com  → enter your email → they email you a key.
# Submissions are emailed to that address.
NEXT_PUBLIC_WEB3FORMS_KEY=

# --- Conversion tracking (optional — tags only load if a value is set) -------
# Meta (Facebook) Pixel ID — e.g. 1234567890
NEXT_PUBLIC_FB_PIXEL_ID=

# Google Analytics 4 Measurement ID — e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion tracking — e.g. AW-XXXXXXXXXX  + the conversion label
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
